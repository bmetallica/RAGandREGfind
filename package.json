{
  "name": "distributed-rag-ingestion-engine",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:ragfind": "tsx watch src/ragfind/server.ts",
    "dev:worker": "tsx watch src/workers/worker.ts",
    "dev:mcp:stdio": "tsx src/mcp/stdio.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:ragfind": "node dist/ragfind/server.js",
    "start:worker": "node dist/workers/worker.js",
    "start:mcp:stdio": "node dist/mcp/stdio.js",
    "migrate": "tsx src/db/runMigrations.ts"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@elastic/elasticsearch": "^8.19.1",
    "@modelcontextprotocol/node": "^2.0.0-alpha.2",
    "@modelcontextprotocol/server": "^2.0.0-alpha.2",
    "axios": "^1.9.0",
    "bullmq": "^5.52.0",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "highlight.js": "^11.11.1",
    "ioredis": "^5.4.1",
    "mammoth": "^1.8.0",
    "marked": "^18.0.3",
    "mime-types": "^2.1.35",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "pdf-parse": "^1.1.1",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^13.0.0",
    "textract": "^2.5.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/mime-types": "^2.1.4",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.1",
    "@types/node-cron": "^3.0.11",
    "@types/pdf-parse": "^1.1.4",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
